<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/visible_bar_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/statusbar_bk"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/signal_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingEnd="3dp"
            android:src="@drawable/signal_5" />

        <ImageView
            android:id="@+id/wifi_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingEnd="3dp"
            android:src="@drawable/wifi3"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/bluetooth_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingEnd="3dp"
            android:src="@drawable/bluetooth"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/message_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingEnd="3dp"
            android:src="@drawable/message_indicator"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/mail_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingEnd="3dp"
            app:srcCompat="@drawable/mail_indicator" />

        <ImageView
            android:id="@+id/media_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingEnd="3dp"
            android:src="@drawable/media_playing"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/status_elements_wrapper"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/battery_percentage_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:text="100%"
            android:textColor="#7FFFFFFF" />

        <TextView
            android:id="@+id/status_bar_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:text="12:00"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="normal|bold" />

        <FrameLayout
            android:id="@+id/battery_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp">

            <ImageView
                android:id="@+id/battery_base"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/battery_100" />

            <ImageView
                android:id="@+id/battery_bolt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/battery_charging_bolt"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>